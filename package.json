{
    "name": "mydoorcamera",
    "version": "0.1.0",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "type": "yarn tsc --noEmit",
        "build-web": "node scripts/writeBuildVersion.js && build-web --indexHtml ./index.html",
        "watch-web": "slift-watch --port 9888 \"web/**/*.ts\" \"web/**/*.tsx\" \"yarn build-web\"",
        "watch": "yarn watch-web",
        "build": "yarn build-web",
        "deploy": "node scripts/deploy.js",
        "ship": "bash scripts/ship.sh"
    },
    "dependencies": {
        "mobx": "^6.13.3",
        "preact": "10.24.3",
        "sliftutils": "^1.4.63",
        "socket-function": "1.1.43",
        "typenode": "^6.0.1",
        "typesafecss": "*"
    }
}
